---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  activeNav?: 'jamfor' | 'om' | 'enummer'
  canonicalPath?: string
  ogType?: 'website' | 'article'
}

const {
  title,
  description = 'Komplett guide till svenska livsmedelsmärkningar – KRAV, Nyckelhålet, Fairtrade, EU-ekologiskt, Svanen och många fler. Lär dig vad märkningarna betyder och hur de kontrolleras.',
  activeNav,
  canonicalPath = '',
  ogType = 'website',
} = Astro.props

const canonicalUrl = `https://markningar.se${canonicalPath}`
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="sv_SE" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-[#f8f7f4] text-[#2c2c2c] antialiased" style="font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; line-height: 1.6;">
    <header class="bg-[#2e6b3e] text-white py-6 px-4 text-center">
      <h1 class="text-2xl font-bold tracking-wide">
        <a href="/" class="text-white hover:opacity-80 transition-opacity no-underline">Svenska livsmedelsmärkningar</a>
      </h1>
      <p class="mt-1 text-sm opacity-85">En guide till märkningar på svenska konsumentvaror</p>

      <nav class="mt-3 flex gap-5 justify-center" aria-label="Huvudnavigering">
        <a
          href="/enummer"
          class={`text-sm transition-opacity ${activeNav === 'enummer' ? 'opacity-100 font-semibold underline' : 'opacity-85 hover:opacity-100'}`}
        >E-nummer</a>
        <a
          href="/jamfor"
          class={`text-sm transition-opacity ${activeNav === 'jamfor' ? 'opacity-100 font-semibold underline' : 'opacity-85 hover:opacity-100'}`}
        >Jämför</a>
        <a
          href="/om"
          class={`text-sm transition-opacity ${activeNav === 'om' ? 'opacity-100 font-semibold underline' : 'opacity-85 hover:opacity-100'}`}
        >Om sidan</a>
      </nav>
    </header>

    <main class="flex-1 max-w-[1100px] mx-auto w-full px-4 py-8">
      <slot />
    </main>

    <footer class="bg-[#2c2c2c] text-white mt-auto py-6 px-4">
      <div class="max-w-[1100px] mx-auto text-center text-sm space-y-1">
        <p class="text-gray-400">Informationen på denna sida är sammanställd i utbildningssyfte och ersätter inte officiella källor.</p>
        <p class="text-gray-400">Webbplatsen ägs av <a href="https://morethanok.io" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-white transition-colors">More Than OK AB</a> och tillhandahålls endast i informationssyfte.</p>
        <p class="text-gray-400">Felaktigheter eller problem? Kontakta <a href="mailto:sites@morethanok.io" class="text-gray-300 hover:text-white transition-colors">sites@morethanok.io</a></p>
        <p class="mt-2"><a href="/om" class="text-gray-300 hover:text-white transition-colors">Om sidan</a></p>
      </div>
    </footer>
  </body>
</html>
